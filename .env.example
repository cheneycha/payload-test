# Database settings
DB_USER=the_db_username
DB_PASSWORD=the_db_password
DB_NAME=payload_prod
DB_HOST=payload-db
DB_PORT=5432

# Connection string for Payload (the format Payload expects)
DATABASE_URI=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Application settings
PAYLOAD_SECRET=the_payload_secret
# Replace 'payload.presspizza.com' with your actual domain
PUBLIC_SERVER_URL=https://payload.presspizza.com
OLS_ADMIN_PASSWORD=the_OLS_Webadmin_password
